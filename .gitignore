# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# CLI self-improvement signals
.pof/

# Claude Code logs + transient agent/idea artifacts
.claude/logs/
.claude/worktrees/
.claude/commands/idea-*

# Windows reserved name artifacts
nul

# typescript
*.tsbuildinfo
next-env.d.ts

# auto-generated by scripts/gen-pipeline-registry.mjs
src/lib/catalog/pipelines/registry.generated.ts

# generated context scan reports
docs/contexts/
