# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# CLI self-improvement signals
.pof/

# Claude Code logs + transient agent/idea artifacts
.claude/logs/
.claude/worktrees/
.claude/commands/idea-*

# Windows reserved name artifacts
nul

# typescript
*.tsbuildinfo
next-env.d.ts

# auto-generated by scripts/gen-pipeline-registry.mjs
src/lib/catalog/pipelines/registry.generated.ts

# generated context scan reports
docs/contexts/

# pof-mcp standalone package (built + installed separately)
tools/pof-mcp/node_modules/
tools/pof-mcp/dist/
# machine-local UE growth ratchet baseline (GROWTH-LOG.md is committed)
tools/pof-mcp/growth-baseline.json

# Local generated 3D assets (zero-budget TripoSR pipeline) — not committed
/generated/

# Playwright seeded storage state (regenerated each run by e2e/global-setup.ts)
/e2e/.auth/

# Bleve docs search index (regenerated, not source)
docs/index.bleve/
