+import { describe, it, expect, afterEach, vi } from 'vitest';
+import { render, screen, fireEvent, cleanup, waitFor, within } from '@testing-library/react';
+import { RegressionTrackerView } from '@/components/modules/game-director/RegressionTrackerView';
+
+afterEach(() => { cleanup(); vi.restoreAllMocks(); });
+
+interface MockResponseSpec { ok: boolean; status: number; body: unknown }
+
+function mockResponse({ ok, status, body }: MockResponseSpec) {
+  return Promise.resolve({
+    ok,
+    status,
+    json: () => Promise.resolve(body),
+    text: () => Promise.resolve(JSON.stringify(body)),
+  });
+}
+
+const emptyStats = {
+  totalTracked: 0, openCount: 0, fixedCount: 0,
+  regressedCount: 0, resolvedCount: 0, activeAlerts: 0, regressionRate: 0,
+};
+
+const sessions = [{ id: 's1', name: 'Session 1', createdAt: '2026-05-01T00:00:00Z', completedAt: null, projectId: 'p1', summary: null }];
+
+function setupFetch({
+  processOk = true,
+  dismissOk = true,
+  resolveOk = true,
+  alerts = [] as unknown[],
+  fingerprints = [] as unknown[],
+}: {
+  processOk?: boolean;
+  dismissOk?: boolean;
+  resolveOk?: boolean;
+  alerts?: unknown[];
+  fingerprints?: unknown[];
+} = {}) {
+  const fetchMock = vi.fn().mockImplementation((url: string, init?: RequestInit) => {
+    if (init?.method === 'POST') {
+      const parsed = init.body ? JSON.parse(init.body as string) : {};
+      if (parsed.action === 'process-session') {
+        return processOk
+          ? mockResponse({ ok: true, status: 200, body: { success: true, data: { sessionId: 's1', sessionName: 'Session 1', generatedAt: '2026-05-26T00:00:00Z', newFindings: [], regressions: [], persistent: [], newlyFixed: [] } } })
+          : mockResponse({ ok: false, status: 500, body: { success: false, error: 'process boom' } });
+      }
+      if (parsed.action === 'dismiss') {
+        return dismissOk
+          ? mockResponse({ ok: true, status: 200, body: { success: true, data: null } })
+          : mockResponse({ ok: false, status: 500, body: { success: false, error: 'dismiss boom' } });
+      }
+      if (parsed.action === 'resolve') {
+        return resolveOk
+          ? mockResponse({ ok: true, status: 200, body: { success: true, data: null } })
+          : mockResponse({ ok: false, status: 500, body: { success: false, error: 'resolve boom' } });
+      }
+      return mockResponse({ ok: true, status: 200, body: { success: true, data: null } });
+    }
+    if (url.includes('action=stats')) return mockResponse({ ok: true, status: 200, body: { success: true, data: emptyStats } });
+    if (url.includes('action=sessions')) return mockResponse({ ok: true, status: 200, body: { success: true, data: sessions } });
+    if (url.includes('action=alerts')) return mockResponse({ ok: true, status: 200, body: { success: true, data: alerts } });
+    if (url.includes('action=fingerprints')) return mockResponse({ ok: true, status: 200, body: { success: true, data: fingerprints } });
+    if (url.includes('action=occurrences')) return mockResponse({ ok: true, status: 200, body: { success: true, data: [] } });
+    return mockResponse({ ok: false, status: 404, body: { success: false, error: 'Not found' } });
+  });
+  globalThis.fetch = fetchMock as unknown as typeof fetch;
+  return fetchMock;
+}
+
+describe('RegressionTrackerView — silent-failure surfacing', () => {
+  it('surfaces handleProcess failures via an inline error banner with Retry', async () => {
+    const fetchMock = setupFetch({ processOk: false });
+    render(<RegressionTrackerView />);
+
+    await waitFor(() => expect(screen.queryByText(/Analyze Session for Regressions/i)).not.toBeNull());
+
+    fireEvent.change(screen.getByRole('combobox'), { target: { value: 's1' } });
+    fireEvent.click(screen.getByRole('button', { name: /Analyze/i }));
+
+    const banner = await screen.findByTestId('regression-process-error');
+    expect(banner.textContent).toMatch(/process boom/);
+
+    const postCalls = () => fetchMock.mock.calls.filter(
+      ([, init]) => (init as RequestInit | undefined)?.method === 'POST',
+    ).length;
+    const before = postCalls();
+    fireEvent.click(screen.getByTestId('regression-process-error-retry'));
+    await waitFor(() => expect(postCalls()).toBe(before + 1));
+  });
+
+  it('clears the process error banner when the session selection changes', async () => {
+    setupFetch({ processOk: false });
+    render(<RegressionTrackerView />);
+    await waitFor(() => expect(screen.queryByText(/Analyze Session for Regressions/i)).not.toBeNull());
+
+    fireEvent.change(screen.getByRole('combobox'), { target: { value: 's1' } });
+    fireEvent.click(screen.getByRole('button', { name: /Analyze/i }));
+    await screen.findByTestId('regression-process-error');
+
+    fireEvent.change(screen.getByRole('combobox'), { target: { value: '' } });
+    expect(screen.queryByTestId('regression-process-error')).toBeNull();
+  });
+
+  it('surfaces handleDismiss failures in the Alerts tab', async () => {
+    const fetchMock = setupFetch({
+      dismissOk: false,
+      alerts: [{
+        id: 'a1', fingerprintId: 'fp1', title: 'Bug X', severity: 'high', category: 'gameplay',
+        buildGap: 2, fixedInSessionId: 's0', fixedInSessionName: 'S0',
+        reappearedInSessionId: 's1', reappearedInSessionName: 'S1',
+        createdAt: '2026-05-25T00:00:00Z', dismissed: false,
+      }],
+    });
+    render(<RegressionTrackerView />);
+    await waitFor(() => expect(screen.queryByText(/Analyze Session for Regressions/i)).not.toBeNull());
+
+    fireEvent.click(screen.getByRole('button', { name: /Regression Alerts/i }));
+
+    const dismissBtn = await screen.findByTitle('Dismiss alert');
+    fireEvent.click(dismissBtn);
+
+    const banner = await screen.findByTestId('regression-dismiss-error');
+    expect(banner.textContent).toMatch(/dismiss boom/);
+
+    const before = fetchMock.mock.calls.length;
+    fireEvent.click(screen.getByTestId('regression-dismiss-error-retry'));
+    await waitFor(() => expect(fetchMock.mock.calls.length).toBeGreaterThan(before));
+  });
+
+  it('surfaces handleResolve failures in the Tracked Issues tab', async () => {
+    const fetchMock = setupFetch({
+      resolveOk: false,
+      fingerprints: [{
+        id: 'fp1', titleStem: 'Stuck idle', category: 'gameplay', relatedModule: 'arpg-character',
+        peakSeverity: 'high', status: 'open', occurrenceCount: 3, regressionCount: 0,
+        firstSeenAt: '2026-05-20T00:00:00Z', lastSeenAt: '2026-05-25T00:00:00Z',
+      }],
+    });
+    render(<RegressionTrackerView />);
+    await waitFor(() => expect(screen.queryByText(/Analyze Session for Regressions/i)).not.toBeNull());
+
+    fireEvent.click(screen.getByRole('button', { name: /Tracked Issues/i }));
+
+    const row = await screen.findByText('Stuck idle');
+    fireEvent.click(row);
+
+    const resolveBtn = await screen.findByRole('button', { name: /Mark Resolved/i });
+    fireEvent.click(resolveBtn);
+
+    const banner = await screen.findByTestId('regression-resolve-error');
+    expect(banner.textContent).toMatch(/resolve boom/);
+
+    const before = fetchMock.mock.calls.length;
+    fireEvent.click(within(banner).getByTestId('regression-resolve-error-retry'));
+    await waitFor(() => expect(fetchMock.mock.calls.length).toBeGreaterThan(before));
+  });
+});
