diff --git a/src/components/ui/ReconnectIndicator.tsx b/src/components/ui/ReconnectIndicator.tsx
new file mode 100644
index 0000000..4d7fdf3
--- /dev/null
+++ b/src/components/ui/ReconnectIndicator.tsx
@@ -0,0 +1,160 @@
+'use client';
+
+/**
+ * ReconnectIndicator
+ *
+ * Compact UI for the PoF Bridge reconnect state. Replaces a static
+ * "Reconnecting..." label with:
+ *   - the attempt number ("Attempt 3")
+ *   - a thin SVG countdown ring (2px stroke) ticking to the next retry
+ *   - a Retry-now / Cancel button pair
+ *
+ * Driven by the existing PofConnectionState (status, reconnectAttempts,
+ * nextRetryAt) and pofBridgeConnection.{retryNow, cancelReconnect}.
+ * Renders nothing unless the bridge is in 'reconnecting' or 'error' status.
+ */
+
+import { useSyncExternalStore } from 'react';
+import { RotateCw, X } from 'lucide-react';
+import { usePofBridgeStore } from '@/stores/pofBridgeStore';
+import { pofBridgeConnection } from '@/lib/pof-bridge/connection-manager';
+import { ACCENT_ORANGE } from '@/lib/chart-colors';
+import { UI_TIMEOUTS } from '@/lib/constants';
+
+interface ReconnectIndicatorProps {
+  /** Outer ring diameter in pixels. */
+  size?: number;
+  /** Ring stroke width in pixels. */
+  strokeWidth?: number;
+  /** Override the accent color used for the ring + buttons. */
+  color?: string;
+  /** Extra className on the outer wrapper. */
+  className?: string;
+}
+
+function clampDelay(attempt: number): number {
+  // Mirrors connection-manager's backoff: base * 2^(attempt-1), capped at max.
+  // attempt is 1-based (the attempt about to fire).
+  const exp = Math.max(0, attempt - 1);
+  return Math.min(
+    UI_TIMEOUTS.pofReconnectBase * Math.pow(2, exp),
+    UI_TIMEOUTS.pofReconnectMax,
+  );
+}
+
+/**
+ * 1-Hz wall-clock subscription via useSyncExternalStore — the idiomatic way to
+ * read live external state in React 19 without tripping `set-state-in-effect`.
+ * When `active` is false we still return Date.now() at render time but skip the
+ * interval, so the component stays cheap.
+ */
+function useNow(active: boolean): number {
+  return useSyncExternalStore(
+    (cb) => {
+      if (!active) return () => {};
+      const id = setInterval(cb, 1000);
+      return () => clearInterval(id);
+    },
+    () => Date.now(),
+    () => Date.now(),
+  );
+}
+
+export function ReconnectIndicator({
+  size = 20,
+  strokeWidth = 2,
+  color = ACCENT_ORANGE,
+  className = '',
+}: ReconnectIndicatorProps) {
+  const status = usePofBridgeStore((s) => s.connectionStatus);
+  const attempt = usePofBridgeStore((s) => s.reconnectAttempts);
+  const nextRetryAt = usePofBridgeStore((s) => s.nextRetryAt);
+
+  // Only render while we're actively backing off or in an error state.
+  const visible = status === 'reconnecting' || status === 'error';
+  const now = useNow(visible && nextRetryAt !== null);
+
+  if (!visible) return null;
+
+  const remainingMs = nextRetryAt !== null ? Math.max(0, nextRetryAt - now) : 0;
+  const remainingSec = Math.ceil(remainingMs / 1000);
+  const totalDelay = clampDelay(Math.max(1, attempt));
+  const progress = nextRetryAt !== null && totalDelay > 0
+    ? 1 - Math.min(1, remainingMs / totalDelay) // 0 → just scheduled, 1 → about to fire
+    : 0;
+
+  const radius = (size - strokeWidth) / 2;
+  const circumference = radius * 2 * Math.PI;
+  const dashOffset = circumference * (1 - progress);
+
+  const attemptLabel = `Attempt ${Math.max(1, attempt)}`;
+  const countdownLabel = remainingMs > 0
+    ? `retrying in ${remainingSec}s`
+    : status === 'error' ? 'paused' : 'retrying…';
+
+  return (
+    <span
+      className={`inline-flex items-center gap-1.5 text-xs font-mono ${className}`}
+      role="status"
+      aria-live="polite"
+      aria-label={`${attemptLabel}, ${countdownLabel}`}
+    >
+      {/* Countdown ring */}
+      <span className="relative inline-flex items-center justify-center" style={{ width: size, height: size }}>
+        <svg
+          width={size}
+          height={size}
+          viewBox={`0 0 ${size} ${size}`}
+          className="-rotate-90"
+          aria-hidden="true"
+        >
+          <circle
+            cx={size / 2}
+            cy={size / 2}
+            r={radius}
+            stroke="var(--border)"
+            strokeWidth={strokeWidth}
+            fill="none"
+          />
+          <circle
+            cx={size / 2}
+            cy={size / 2}
+            r={radius}
+            stroke={color}
+            strokeWidth={strokeWidth}
+            fill="none"
+            strokeDasharray={circumference}
+            strokeDashoffset={dashOffset}
+            strokeLinecap="round"
+            className="rounded-full transition-[stroke-dashoffset] duration-1000 ease-linear"
+          />
+        </svg>
+      </span>
+
+      <span style={{ color }}>{attemptLabel}</span>
+      <span className="text-text-muted">·</span>
+      <span className="text-text-muted tabular-nums">{countdownLabel}</span>
+
+      <button
+        type="button"
+        onClick={() => pofBridgeConnection.retryNow()}
+        title="Retry now"
+        aria-label="Retry connection now"
+        className="ml-1 inline-flex items-center gap-1 px-1.5 py-0.5 rounded border border-border hover:bg-surface-hover text-text-muted hover:text-text transition-colors focus-ring"
+      >
+        <RotateCw className="w-3 h-3" aria-hidden="true" />
+        <span className="hidden sm:inline">Retry</span>
+      </button>
+      <button
+        type="button"
+        onClick={() => pofBridgeConnection.cancelReconnect()}
+        title="Cancel"
+        aria-label="Cancel reconnection"
+        className="inline-flex items-center gap-1 px-1.5 py-0.5 rounded border border-border hover:bg-surface-hover text-text-muted hover:text-text transition-colors focus-ring"
+      >
+        <X className="w-3 h-3" aria-hidden="true" />
+        <span className="hidden sm:inline">Cancel</span>
+      </button>
+    </span>
+  );
+}
