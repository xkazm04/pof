@@ -0,0 +1,104 @@
+import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
+import { render, cleanup, fireEvent } from '@testing-library/react';
+import { ReconnectIndicator } from '@/components/ui/ReconnectIndicator';
+import { usePofBridgeStore } from '@/stores/pofBridgeStore';
+import { pofBridgeConnection } from '@/lib/pof-bridge/connection-manager';
+
+beforeEach(() => {
+  usePofBridgeStore.setState({
+    connectionStatus: 'disconnected',
+    reconnectAttempts: 0,
+    nextRetryAt: null,
+    pluginInfo: null,
+    error: null,
+  });
+});
+
+afterEach(() => {
+  cleanup();
+});
+
+describe('ReconnectIndicator', () => {
+  it('renders nothing when status is connected', () => {
+    usePofBridgeStore.setState({ connectionStatus: 'connected' });
+    const { container } = render(<ReconnectIndicator />);
+    expect(container.firstChild).toBeNull();
+  });
+
+  it('renders nothing when status is disconnected', () => {
+    usePofBridgeStore.setState({ connectionStatus: 'disconnected' });
+    const { container } = render(<ReconnectIndicator />);
+    expect(container.firstChild).toBeNull();
+  });
+
+  it('shows the attempt number while reconnecting', () => {
+    usePofBridgeStore.setState({
+      connectionStatus: 'reconnecting',
+      reconnectAttempts: 3,
+      nextRetryAt: Date.now() + 4_000,
+    });
+    const { getByText } = render(<ReconnectIndicator />);
+    expect(getByText('Attempt 3')).toBeTruthy();
+  });
+
+  it('shows a countdown when nextRetryAt is set', () => {
+    usePofBridgeStore.setState({
+      connectionStatus: 'reconnecting',
+      reconnectAttempts: 1,
+      nextRetryAt: Date.now() + 4_000,
+    });
+    const { getByText } = render(<ReconnectIndicator />);
+    expect(getByText(/retrying in \ds/)).toBeTruthy();
+  });
+
+  it('renders an SVG ring with stroke-width 2 by default', () => {
+    usePofBridgeStore.setState({
+      connectionStatus: 'reconnecting',
+      reconnectAttempts: 1,
+      nextRetryAt: Date.now() + 2_000,
+    });
+    const { container } = render(<ReconnectIndicator />);
+    const circles = container.querySelectorAll('circle');
+    expect(circles.length).toBe(2);
+    for (const c of Array.from(circles)) {
+      expect(c.getAttribute('stroke-width')).toBe('2');
+    }
+  });
+
+  it('calls retryNow() on the connection manager when Retry is clicked', () => {
+    const spy = vi.spyOn(pofBridgeConnection, 'retryNow').mockImplementation(() => {});
+    usePofBridgeStore.setState({
+      connectionStatus: 'reconnecting',
+      reconnectAttempts: 2,
+      nextRetryAt: Date.now() + 4_000,
+    });
+    const { getByLabelText } = render(<ReconnectIndicator />);
+    fireEvent.click(getByLabelText('Retry connection now'));
+    expect(spy).toHaveBeenCalledTimes(1);
+    spy.mockRestore();
+  });
+
+  it('calls cancelReconnect() on the connection manager when Cancel is clicked', () => {
+    const spy = vi.spyOn(pofBridgeConnection, 'cancelReconnect').mockImplementation(() => {});
+    usePofBridgeStore.setState({
+      connectionStatus: 'reconnecting',
+      reconnectAttempts: 2,
+      nextRetryAt: Date.now() + 4_000,
+    });
+    const { getByLabelText } = render(<ReconnectIndicator />);
+    fireEvent.click(getByLabelText('Cancel reconnection'));
+    expect(spy).toHaveBeenCalledTimes(1);
+    spy.mockRestore();
+  });
+
+  it('renders in error state (no countdown) as "paused"', () => {
+    usePofBridgeStore.setState({
+      connectionStatus: 'error',
+      reconnectAttempts: 5,
+      nextRetryAt: null,
+    });
+    const { getByText } = render(<ReconnectIndicator />);
+    expect(getByText('Attempt 5')).toBeTruthy();
+    expect(getByText('paused')).toBeTruthy();
+  });
+});
